{
  "name": "aiimage-cli",
  "version": "1.1.0",
  "description": "AI画像生成CLI - Gemini, fal.ai, SVG Diagram, Mermaid変換をサポート",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "aiimage": "bin/aiimage.js",
    "aidiagram": "bin/aidiagram.js",
    "aimermaid": "bin/aimermaid.js"
  },
  "scripts": {
    "test": "node --check src/index.js bin/aiimage.js bin/aidiagram.js bin/aimermaid.js",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run test && npm run pack:check"
  },
  "keywords": [
    "ai",
    "image",
    "generation",
    "gemini",
    "fal",
    "gpt-image",
    "diagram",
    "svg",
    "mermaid",
    "cli"
  ],
  "author": "Masao",
  "license": "MIT",
  "files": [
    "bin/*.js",
    "src/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@fal-ai/client": "^1.2.1",
    "@google/generative-ai": "^0.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "open": "^10.1.0"
  },
  "optionalDependencies": {
    "@xmldom/xmldom": "^0.9.0",
    "sharp": "^0.33.0"
  },
  "peerDependencies": {
    "@mermaid-js/mermaid-cli": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@mermaid-js/mermaid-cli": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
